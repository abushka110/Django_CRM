#: website/forms.py:34
msgid ""
"<span class=\"form-text text-muted\"><small>Required. 150 characters or "
"fewer. Letters, digits and @/./+/-/_ only.</small></span>"
msgstr ""
"<span class=\"form-text text-muted\"><small>Erforderlich. Maximal 150 "
"Zeichen. Buchstaben, Ziffern und @/./+/-/_ erlaubt.</small></span>"

#: website/forms.py:38
msgid "Password"
msgstr "Passwort"

#: website/forms.py:41
msgid ""
"<ul class=\"form-text text-muted small\"><li>Your password can't be too "
"similar to your other personal information.</li><li>Your password must "
"contain at least 8 characters.</li><li>Your password can't be a commonly "
"used password.</li><li>Your password can't be entirely numeric.</li></ul>"
msgstr ""
"<ul class=\"form-text text-muted small\"><li>Das Passwort darf nicht zu "
"ähnlich zu persönlichen Angaben sein.</li><li>Es muss mindestens 8 Zeichen "
"enthalten.</li><li>Es darf kein häufig verwendetes Passwort sein.</li><li>Es "
"darf nicht ausschließlich aus Zahlen bestehen.</li></ul>"

#: website/forms.py:50
msgid "Confirm Password"
msgstr "Passwort bestätigen"

#: website/forms.py:53
msgid ""
"<span class=\"form-text text-muted\"><small>Enter the same password as "
"before, for verification.</small></span>"
msgstr ""
"<span class=\"form-text text-muted\"><small>Geben Sie dasselbe Passwort "
"erneut zur Bestätigung ein.</small></span>"

